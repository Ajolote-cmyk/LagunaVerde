    doRepair(workspace:WaitForChild("FacilitySystems"):WaitForChild("Feedwater"):WaitForChild("FWPumpA"):WaitForChild("Repair"))
    doRepair(workspace:WaitForChild("FacilitySystems"):WaitForChild("Turbines"):WaitForChild("TurbineBeta"):WaitForChild("Repair"))
    doRepair(workspace:WaitForChild("FacilitySystems"):WaitForChild("JunctionBoxes"):WaitForChild("JunctionBox"):WaitForChild("Hitbox"))
    doRepair(workspace:WaitForChild("FacilitySystems"):WaitForChild("Turbines"):WaitForChild("TurbineAlpha"):WaitForChild("Repair"))
    doRepair(workspace:WaitForChild("FacilitySystems"):WaitForChild("Generators"):WaitForChild("Generator1"):WaitForChild("Repair"))
    doRepair(workspace:WaitForChild("FacilitySystems"):WaitForChild("Generators"):WaitForChild("Generator2"):WaitForChild("Repair"))
